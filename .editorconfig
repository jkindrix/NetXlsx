root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,yml,yaml,json,xml,csproj,props,targets,config,sln}]
indent_size = 2

[*.cs]
# Sort using directives
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Var preferences — prefer explicit types
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion

# Modern C# preferences
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_inlined_variable_declaration = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion
csharp_prefer_simple_default_expression = true:suggestion

# Namespace style — file-scoped
csharp_style_namespace_declarations = file_scoped:warning

# Braces
csharp_prefer_braces = when_multiline:suggestion

# Code-quality rule severities for public API correctness
dotnet_diagnostic.CS1591.severity = error                # Missing XML doc on public API
dotnet_diagnostic.RS0016.severity = error                # PublicApiAnalyzer: undeclared API
dotnet_diagnostic.RS0017.severity = error                # PublicApiAnalyzer: stale public API entry

# Intentional overloads with optional parameters (SaveAsync, OpenAsync, etc.).
# The analyzer's concern is ambiguity when adding NEW optional parameters
# later; we accept that trade for ergonomic call sites.
dotnet_diagnostic.RS0026.severity = none

# Enum value names mirror the design spec (CellKind.String, CellKind.Date,
# etc.); the "identifier contains type name" rule does not apply to a
# value-classification enum.
dotnet_diagnostic.CA1720.severity = none

[tests/**/*.cs]
# Tests don't need XML doc
dotnet_diagnostic.CS1591.severity = none
# Test naming convention is Method_Scenario_Expected (design S4); underscores allowed
dotnet_diagnostic.CA1707.severity = none
# These analyzer rules add noise in tests
dotnet_diagnostic.CA1860.severity = none
dotnet_diagnostic.CA1515.severity = none

[benchmarks/**/*.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1707.severity = none

[samples/**/*.cs]
dotnet_diagnostic.CS1591.severity = none
