<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- TODO: replace placeholder when public NuGet feed URL is known.
         <add key="cma-internal" value="https://NUGET_FEED/v3/index.json" protocolVersion="3" />
    -->
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <!-- When the internal feed is added, route NetXlsx.* packages there:
    <packageSource key="cma-internal">
      <package pattern="NetXlsx.*" />
    </packageSource>
    -->
  </packageSourceMapping>
</configuration>
